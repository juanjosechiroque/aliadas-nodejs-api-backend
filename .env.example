# =============================================================================
# Aliadas API — variables de entorno (copiar a .env y rellenar; no commitear .env)
# =============================================================================

# --- Servidor ---
# Puerto HTTP (local: 3330 = environment.apiBaseUrl del front).
PORT=3330

# production → cookie JWT Secure + SameSite=None (necesario si el front está en otro dominio).
# development → cookie SameSite=Lax (el front en otro origen debe usar Bearer; ver respuesta login).
# NODE_ENV=development

# --- JWT (obligatorios; sin ellos el proceso termina al arrancar) ---
# Secreto largo y aleatorio en producción (mín. 32 caracteres recomendado).
JWT_SECRET=

# Duración del token (formato jsonwebtoken: 2h, 30m, 7d, o segundos como número).
JWT_EXPIRES_IN=2h

# --- Supabase (lecturas/escrituras según ruta) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Opcional: si algún modelo lee con anon en lugar de service role.
# SUPABASE_ANON_KEY=

# Bucket de imágenes de noticias (default aliadas-news si se omite).
# SUPABASE_NEWS_BUCKET=aliadas-news

# --- CORS ---
# El código actual usa origin: true + credentials: true (refleja el Origin del cliente).
# Asegurate de que el front use la URL exacta del API en environment.apiBaseUrl.

# --- Rate limit POST /api/users/login (opcional) ---
# RATE_LIMIT_LOGIN_MAX=15
# RATE_LIMIT_LOGIN_WINDOW_MS=900000
